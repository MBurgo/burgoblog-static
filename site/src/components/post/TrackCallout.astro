---
// "Now playing" track callout used inline in post bodies. Mimics the
// `NO. 01` numbered album block from the design — sleeve + meta + listen chips.
import AlbumSleeve from './AlbumSleeve.astro';

interface Props {
  number?: string;
  artist: string;
  title: string;
  body?: string;
  tone?: 'rust' | 'cream' | 'ink' | 'mustard' | 'olive';
  sleeveLabel?: string;
  sleeveSub?: string;
  spotify?: string;
  apple?: string;
}
const {
  number = 'NO. 01',
  artist,
  title,
  body,
  tone = 'cream',
  sleeveLabel,
  sleeveSub,
  spotify,
  apple,
} = Astro.props;
---

<div class="relative grid grid-cols-[160px_1fr] gap-6 bg-paper-2 p-5 my-8" style="box-shadow:inset 0 0 0 1px rgba(0,0,0,.06);">
  <span class="absolute -top-2.5 left-5 font-mono text-[10.5px] tracking-kicker bg-ink text-paper px-2.5 py-1">{number}</span>
  <AlbumSleeve size={160} label={sleeveLabel ?? title.toUpperCase()} sub={sleeveSub ?? artist.toUpperCase()} tone={tone} />
  <div>
    <div class="eyebrow">{artist}</div>
    <h3 class="font-display text-4xl leading-none mt-1 mb-2" style="letter-spacing:-0.01em;">{title}</h3>
    {body && <p class="m-0 font-serif text-[17px] leading-relaxed text-ink-2"><Fragment set:html={body} /></p>}
    <div class="mt-3 flex gap-2 font-mono text-[10.5px] tracking-track">
      <span class="px-2.5 py-1 bg-oxblood text-paper">♪ LISTEN</span>
      {spotify && <a href={spotify} class="px-2.5 py-1 border border-ink" rel="noopener">SPOTIFY</a>}
      {apple && <a href={apple} class="px-2.5 py-1 border border-ink" rel="noopener">APPLE MUSIC</a>}
    </div>
  </div>
</div>
