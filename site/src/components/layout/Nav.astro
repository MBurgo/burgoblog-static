---
// Track-listing-styled primary nav. Each item gets a numbered tracklist
// digit + section name. The route handler keeps the legacy paths.
const items: Array<[string, string, string]> = [
  ['01', 'Popular Posts', '/popular-posts/'],
  ['02', 'About', '/about-3/'],
  ['03', 'Music Policy', '/music-policy/'],
  ['04', 'Contact', '/contact/'],
  ['05', 'Feature your band', '/want-your-band-featured-here/'],
];
---

<nav aria-label="Primary" class="mx-4 md:mx-14 border-t-[1.5px] border-ink border-b border-dashed border-b-rule">
  <ul class="m-0 p-0 list-none grid grid-cols-2 md:grid-cols-5">
    {items.map(([n, label, href], i) => (
      <li class={i === 0 ? '' : 'md:border-l border-rule'}>
        <a
          href={href}
          class="flex items-baseline gap-3 py-3 px-3 md:px-5 min-h-[44px] box-border hover:text-oxblood"
        >
          <span class="font-mono text-[11px] tracking-track text-oxblood">{n}</span>
          <span class="font-display text-[18px] md:text-[22px] text-ink">{label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>
