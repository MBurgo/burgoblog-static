---
// "The Vault" — a row of records standing on a shelf, one per year.
// Spine heights scale logarithmically with post count so single-post
// years stay legible while 2008 (the heaviest year) doesn't dwarf them.
// Hover/focus reveals the year's three highest-commented posts.
//
// The spine container is a <div>, NOT an <a>: the popover contains
// per-post <a> links, and HTML5 parsers refuse to nest <a> tags —
// they auto-close the outer one and reparent the inner content as
// siblings of the wrapper, which previously left the <ol> floating
// outside the popover and broke the hover layout. The year-archive
// link instead lives on the spine body itself (one <a>, no nesting).
import type { YearGroup } from '@/lib/data';

interface Props {
  years: YearGroup[];
  totalPosts: number;
}
const { years, totalPosts } = Astro.props;

const PALETTE = ['#8a2a1c', '#1a140c', '#c58a2e', '#5e6b3a', '#e9d9b3', '#3a2f22'];
const LIGHT_TONES = new Set(['#e9d9b3', '#c58a2e']);

const firstYear = years[0]?.year ?? new Date().getFullYear();
const lastYear = years[years.length - 1]?.year ?? new Date().getFullYear();

const spines = years.map((y, idx) => {
  const height = 90 + Math.log(y.count + 1) * 30;
  const color = PALETTE[y.year % PALETTE.length];
  const onLight = LIGHT_TONES.has(color);
  let popPin: 'left' | 'right' | 'center' = 'center';
  if (idx < 2) popPin = 'left';
  else if (idx > years.length - 3) popPin = 'right';
  return { y, height, color, onLight, popPin };
});
---

<section class="relative px-4 md:px-14 pt-16">
  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-3">
    <div class="flex items-baseline gap-4 flex-wrap">
      <span class="kicker">THE VAULT</span>
      <span class="font-display text-2xl md:text-4xl leading-none">{lastYear - firstYear + 1} years of back catalog.</span>
    </div>
    <span class="meta">{firstYear} → {lastYear} · {totalPosts} POSTS</span>
  </div>

  <div class="vault-shelf flex items-end gap-2 px-6 py-7 bg-paper-2 border-b-[6px] border-ink overflow-x-auto md:overflow-visible">
    {spines.map(({ y, height, color, onLight, popPin }) => (
        <div class="vault-spine flex-1 min-w-[40px] flex flex-col items-center gap-2">
          <span class="font-mono text-[10px] tracking-track text-ink-3">{y.count} {y.count === 1 ? 'post' : 'posts'}</span>
          <a
            href={`/archive/${y.year}/`}
            class="vault-spine__body w-full flex items-center justify-center font-display text-2xl md:text-3xl"
            style={`height:${height}px;background:${color};color:${onLight ? '#1a140c' : '#f3ead6'};writing-mode:vertical-rl;text-orientation:mixed;letter-spacing:0.04em;box-shadow:inset 0 0 0 1px rgba(0,0,0,.25), 0 4px 10px rgba(0,0,0,.15);`}
            aria-label={`${y.year} archive — ${y.count} ${y.count === 1 ? 'post' : 'posts'}`}
          >{y.year}</a>
          <div class={`vault-pop vault-pop--${popPin} p-4 bg-paper text-ink`} role="tooltip">
            <div class="vault-pop__head flex justify-between items-baseline pb-2 mb-2.5 border-b border-ink font-mono text-[10.5px] tracking-kicker text-ink-3">
              <span class="font-display text-3xl leading-none text-ink" style="letter-spacing:-0.01em;">{y.year}</span>
              <span>{y.count} {y.count === 1 ? 'POST' : 'POSTS'}</span>
            </div>
            <ol class="vault-pop__list list-none m-0 p-0 flex flex-col gap-2">
              {y.top.map((entry, i) => (
                <li class="grid grid-cols-[22px_1fr] gap-2 items-baseline font-serif text-[15px] leading-snug text-ink">
                  <span class="font-mono text-[10.5px] tracking-track text-oxblood">{String(i + 1).padStart(2, '0')}</span>
                  <a href={entry.permalink} class="hover:text-oxblood">{entry.title}</a>
                </li>
              ))}
            </ol>
            {y.count > y.top.length && (
              <a
                href={`/archive/${y.year}/`}
                class="vault-pop__more block mt-3 pt-2.5 border-t border-dashed border-rule font-mono text-[10.5px] tracking-kicker text-oxblood"
              >SEE ALL {y.count} →</a>
            )}
          </div>
        </div>
      ))}
  </div>
</section>

<style is:global>
  /* Vault — record-spine shelf with on-hover popovers. Hover/focus-within
     because the spine container is a <div> (not focusable on its own),
     and the focusable child <a> elements need to drive the popover. */
  .vault-spine {
    position: relative;
  }
  .vault-spine__body {
    position: relative;
    text-decoration: none;
    transition: transform 0.18s cubic-bezier(0.2, 0.7, 0.3, 1), box-shadow 0.18s;
  }
  .vault-spine:hover .vault-spine__body,
  .vault-spine:focus-within .vault-spine__body {
    transform: translateY(-10px);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.3), 0 14px 22px rgba(20,15,8,.3);
  }
  .vault-pop {
    position: absolute;
    bottom: 100%;
    margin-bottom: 14px;
    min-width: 260px;
    max-width: 300px;
    box-shadow: 0 18px 30px rgba(20,15,8,.25), inset 0 0 0 1.5px var(--ink);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.15s,
      transform 0.18s cubic-bezier(0.2, 0.7, 0.3, 1),
      visibility 0s linear 0.15s;
    z-index: 4;
  }
  .vault-pop--left {
    left: 0;
    right: auto;
    transform: translateY(6px);
  }
  .vault-pop--right {
    right: 0;
    left: auto;
    transform: translateY(6px);
  }
  .vault-pop--center {
    left: 50%;
    transform: translate(-50%, 6px);
  }
  .vault-pop::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    width: 14px;
    height: 14px;
    background: var(--paper);
    transform: translate(-50%, -7px) rotate(45deg);
    box-shadow: 1px 1px 0 0 var(--ink);
  }
  .vault-spine:hover .vault-pop,
  .vault-spine:focus-within .vault-pop {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity 0.15s,
      transform 0.18s cubic-bezier(0.2, 0.7, 0.3, 1),
      visibility 0s;
  }
  .vault-spine:hover .vault-pop--left,
  .vault-spine:focus-within .vault-pop--left,
  .vault-spine:hover .vault-pop--right,
  .vault-spine:focus-within .vault-pop--right {
    transform: translateY(0);
  }
  .vault-spine:hover .vault-pop--center,
  .vault-spine:focus-within .vault-pop--center {
    transform: translate(-50%, 0);
  }
</style>
