---
import Base from '../layouts/Base.astro';
import TopUtility from '../components/layout/TopUtility.astro';
import Footer from '../components/layout/Footer.astro';
import Stamp from '../components/ui/Stamp.astro';
import Button from '../components/ui/Button.astro';
---

<Base title="404 · Track not found · Burgo's Music Blog">
  <TopUtility compact />

  <main id="main" class="relative px-4 md:px-14 pt-16 pb-20 text-center max-w-[820px] mx-auto">
    <div class="flex justify-center mb-8">
      <Stamp size={140} top="SIDE B · NEVER · PRESSED" center={'404'} rotate={-4} />
    </div>
    <h1 class="font-display text-[clamp(48px,10vw,120px)] m-0" style="line-height:0.9;letter-spacing:-0.025em;">
      Track not found.
    </h1>
    <p class="font-serif italic text-xl text-ink-2 mt-4">
      This record's not in the catalog. Maybe it never was — or maybe it got filed under a different sleeve. Try searching the archive instead.
    </p>

    <form class="mt-10 max-w-[520px] mx-auto" role="search" onsubmit="return false;">
      <label for="q" class="kicker block text-left mb-2">SEARCH THE ARCHIVE</label>
      <input
        id="q"
        type="search"
        placeholder="artist, album, song…"
        autocomplete="off"
        class="w-full bg-paper-2 px-5 py-3.5 font-serif text-lg text-ink"
        style="box-shadow:inset 0 0 0 1.5px rgba(26,20,12,.85);"
      />
    </form>
    <ul id="search-results" class="mt-6 max-w-[600px] mx-auto text-left list-none p-0 m-0 hidden">
    </ul>
    <p id="search-empty" class="meta mt-6 hidden">NO MATCHES.</p>

    <div class="mt-10 flex flex-wrap gap-4 justify-center">
      <Button href="/">Back to the index</Button>
      <a href="/popular-posts/" class="underline underline-offset-4 hover:text-oxblood">Or try the popular posts →</a>
    </div>
  </main>

  <Footer />
</Base>

<script is:inline>
  (function () {
    var input = document.getElementById('q');
    var list = document.getElementById('search-results');
    var empty = document.getElementById('search-empty');
    var indexPromise = null;
    function loadIndex() {
      if (!indexPromise) {
        indexPromise = fetch('/search-index.json').then(function (r) { return r.json(); });
      }
      return indexPromise;
    }
    function render(results) {
      list.innerHTML = '';
      if (results.length === 0) {
        list.classList.add('hidden');
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');
      list.classList.remove('hidden');
      results.slice(0, 20).forEach(function (r) {
        var li = document.createElement('li');
        li.className = 'py-2 border-b border-ink-3/20';
        li.innerHTML =
          '<a href="' + r.permalink + '" class="block hover:text-oxblood">' +
          '<span class="font-display text-xl block leading-tight">' + r.title.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</span>' +
          '<span class="meta">' + r.year + '</span>' +
          '</a>';
        list.appendChild(li);
      });
    }
    function filter(q, idx) {
      q = q.trim().toLowerCase();
      if (!q) { list.classList.add('hidden'); empty.classList.add('hidden'); return; }
      var terms = q.split(/\s+/);
      var hits = idx.filter(function (r) {
        var t = r.title.toLowerCase();
        return terms.every(function (term) { return t.indexOf(term) !== -1; });
      });
      render(hits);
    }
    if (input) {
      input.addEventListener('input', function () {
        loadIndex().then(function (idx) { filter(input.value, idx); });
      });
      input.focus();
    }
  })();
</script>
