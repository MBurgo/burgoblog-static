---
import Post from '../../../../layouts/Post.astro';
import { getSortedPosts } from '@/lib/data';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  return posts.map((post, i) => {
    const d = post.data.date;
    // Strip the YYYY-MM-DD- prefix Task 1's extractor encodes in the
    // filename so the URL slug matches the original WP permalink.
    const slugFromFile = post.slug.replace(/^\d{4}-\d{2}-\d{2}-/, '');
    return {
      params: {
        year: String(d.getFullYear()),
        month: String(d.getMonth() + 1).padStart(2, '0'),
        day: String(d.getDate()).padStart(2, '0'),
        slug: slugFromFile,
      },
      props: {
        post,
        // Posts are sorted newest first, so prev (older) is the next entry
        // in the list and next (newer) is the previous one.
        prev: posts[i + 1] ?? null,
        next: posts[i - 1] ?? null,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content } = await post.render();
---

<Post post={post} prev={prev} next={next}>
  <Content />
</Post>
