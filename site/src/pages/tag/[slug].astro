---
import Archive from '../../layouts/Archive.astro';
import ArchiveList from '../../components/archive/ArchiveList.astro';
import { getSortedPosts, tags } from '@/lib/data';

export async function getStaticPaths() {
  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const all = await getSortedPosts();
const posts = all.filter((post) =>
  post.data.tags.some((t) => t.toLowerCase().replace(/\s+/g, '-') === tag.slug),
);
---

<Archive
  title={tag.name}
  eyebrow="TAGGED"
  meta={`${posts.length} ${posts.length === 1 ? 'POST' : 'POSTS'} TAGGED &ldquo;${tag.name.toUpperCase()}&rdquo;`}
>
  {posts.length === 0 ? (
    <p class="font-serif italic text-ink-3">No posts have been migrated under this tag yet. Task 3 will bring them across.</p>
  ) : (
    <ArchiveList posts={posts} />
  )}
</Archive>
